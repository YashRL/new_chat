# ─── DATABASE (SQLite) ───────────────────────────────────────────────────────
SQLITE_PATH=knowledge.db

# ─── JWT SECRET (generate with: python -c "import secrets; print(secrets.token_hex(32))") ─
SECRET_KEY=your_jwt_secret_key_here_replace_with_random_hex

# ─── ALLOWED ORIGINS (comma-separated, no trailing slash) ────────────────────
# For local development: http://localhost:3000,http://localhost:5173
# For production: https://yourapp.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── OpenAI Embeddings ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── NVIDIA NIM — Generation / Reranking API ─────────────────────────────────
# Get key from: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_RERANK_MODEL=nvidia/nv-rerankqa-mistral-4b-v3

# ─── GENERATION MODEL (NVIDIA NIM) ──────────────────────────────────────────
# Options (all available on NIM with your API key):
#   meta/llama-3.3-70b-instruct   — best quality
#   meta/llama-3.1-8b-instruct    — fastest, lowest cost
#   mistralai/mistral-large-2-instruct
LLM_MODEL=meta/llama-3.3-70b-instruct
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1

# ─── RAG GENERATION SETTINGS ─────────────────────────────────────────────────
RAG_MAX_CONTEXT_TOKENS=3000
RAG_TOP_K=8
RAG_STREAM_DEFAULT=true

# ─── FEATURE FLAGS ───────────────────────────────────────────────────────────
RERANK_ENABLED=false
HYDE_ENABLED=false
QUERY_DECOMPOSITION_ENABLED=true

# ─── RATE LIMITING ───────────────────────────────────────────────────────────
RATE_LIMIT_SEARCH=60/minute
RATE_LIMIT_ANSWER=30/minute
RATE_LIMIT_INGEST=10/minute

# ─── MIGRATIONS ───────────────────────────────────────────────────────────────
MIGRATIONS_DIR=db/migrations
